<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <!-- 2026-05-21: parent forced to Light (was DayNight). Two real users
         reported "black screen on input focus" on Android: when the soft
         keyboard opens, Keyboard.resize='native' shrinks the WebView, the
         body content briefly fails to fill the new viewport, and the
         Activity background paints through. DayNight on a phone in dark
         mode = black activity background → the user sees a black gap
         between the fixed top header and the keyboard. Light theme +
         explicit white windowBackground gives a benign white gap during
         that same race instead of an alarming black void. The React app
         itself has no dark-mode UI, so locking the Android theme to Light
         doesn't lose functionality. -->
    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <!-- White windowBackground: critical safety net. BridgeActivity does
             not call SplashScreen.installSplashScreen(), so the launch
             theme's green splash drawable would persist as the window
             backdrop without this. MainActivity.onCreate also calls
             setBackgroundDrawable(WHITE) as belt-and-suspenders. -->
        <item name="android:windowBackground">@android:color/white</item>
        <!-- windowLightStatusBar=false: white status-bar icons (over the
             dark green CSS-painted status bar in Layout.jsx).
             windowLightNavigationBar=true: dark gesture-bar icons (over
             the white BottomNav background that extends to the bottom). -->
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">true</item>
        <!-- We are committed to edge-to-edge across all Android versions.
             MainActivity calls WindowCompat.setDecorFitsSystemWindows(false)
             explicitly. The WebView covers the whole window; CSS receives
             the inset values via injected --android-inset-* variables
             and lays out content accordingly.
             setStatusBarColor / setNavigationBarColor were here previously
             but are deprecated on API 35+ (we target SDK 36). The system
             bar regions are painted in CSS instead — see Layout.jsx mobile
             top bar (#2D5233) and BottomNav (white) which already extend
             into the inset regions. -->
    </style>


    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
        <!-- After splash fades, hand control to the NoActionBar theme so the
             edge-to-edge opt-out + system bar colors from there take effect. -->
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>
</resources>
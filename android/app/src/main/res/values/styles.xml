<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <!-- 2026-05-21: parent forced to Light (was DayNight). Two real users
         reported "black screen on input focus" on Android: when the soft
         keyboard opens, Keyboard.resize='native' shrinks the WebView, the
         body content briefly fails to fill the new viewport, and the
         Activity background paints through. DayNight on a phone in dark
         mode = black activity background → the user sees a black gap
         between the fixed top header and the keyboard. Light theme +
         explicit white windowBackground gives a benign white gap during
         that same race instead of an alarming black void. The React app
         itself has no dark-mode UI, so locking the Android theme to Light
         doesn't lose functionality. -->
    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <!-- Was @null which left the Activity background unpainted, exposing
             whatever the window manager renders underneath. Explicit white
             matches the React app's white body bg + the iOS WebView
             backgroundColor='#FFFFFF' in capacitor.config.ts. -->
        <item name="android:windowBackground">@android:color/white</item>
        <!-- System bar colors so the app's top/bottom chrome blends with them -->
        <item name="android:statusBarColor">#2D5233</item>
        <item name="android:navigationBarColor">#FFFFFF</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">true</item>
        <!-- Android 15+ (target SDK 35+) forces edge-to-edge by default, which
             makes the WebView draw UNDER the status bar + gesture navigation.
             Opt out so system bars are respected and the in-app top/bottom
             chrome sits in the real viewport — like every standard Android app. -->
        <item name="android:windowOptOutEdgeToEdgeEnforcement">true</item>
    </style>


    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
        <!-- After splash fades, hand control to the NoActionBar theme so the
             edge-to-edge opt-out + system bar colors from there take effect. -->
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>
</resources>
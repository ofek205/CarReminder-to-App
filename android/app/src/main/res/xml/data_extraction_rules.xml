<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ data-extraction policy.

    Both branches deny the entire app domain. Combined with allowBackup=false
    + fullBackupContent=false on the <application> tag, this stops Android from
    including any of our private files in:
      - cloud-backup  (Google Drive auto-backup)
      - device-transfer (D2D copy when the user moves to a new phone)

    Why we want it: Capacitor Preferences (which holds the Supabase access +
    refresh tokens since src/lib/supabase.js was migrated) lives under the
    app's private storage. With the previous allowBackup=true default, those
    tokens could end up in Google Drive backups; restoring the backup on a
    different device would resume the session. We'd rather force the user to
    sign in again on a new device.

    If a future feature needs to back up something specific (e.g. a settings
    file), allow it explicitly with <include domain="..." path="..."/> rather
    than relaxing the global deny.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>

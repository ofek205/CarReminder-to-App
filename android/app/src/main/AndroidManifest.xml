<?xml version="1.0" encoding="utf-8" ?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <application
        android:allowBackup="false"
        android:fullBackupContent="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">
        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Deep link: carreminder://vehicle/<id>, carreminder://document/<id>, etc. -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="carreminder" />
            </intent-filter>

            <!-- App links: https://car-reminder.app/... opens inside the app
                 (App Links verification can be turned on later via assetlinks.json) -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="car-reminder.app" />
                <data android:scheme="https" android:host="www.car-reminder.app" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data android:name="android.support.FILE_PROVIDER_PATHS" android:resource="@xml/file_paths" />
        </provider>
    </application>

    <!-- Hardware feature declarations.
         CRITICAL: Google Play AUTO-DERIVES feature requirements from
         permissions if we don't override. Specifically:
           CAMERA permission       → adds <uses-feature camera required="true"/>
           ACCESS_FINE_LOCATION    → adds <uses-feature location.gps required="true"/>
           ACCESS_COARSE_LOCATION  → adds <uses-feature location.network required="true"/>
         Devices missing those features (some tablets without GPS, devices
         with no camera, emulators, restricted Samsung profiles, ChromeOS
         laptops) get "This app is available only for your other devices"
         in the Play Store — even when minSdk and architecture match.
         Declaring them here with required="false" tells Play that the
         app USES these capabilities when available but doesn't NEED them,
         widening device compatibility without removing functionality
         (CameraPicker / Geolocation fail gracefully when absent). -->
    <uses-feature android:name="android.hardware.camera"            android:required="false" />
    <uses-feature android:name="android.hardware.camera.autofocus"  android:required="false" />
    <uses-feature android:name="android.hardware.camera.any"        android:required="false" />
    <uses-feature android:name="android.hardware.location"          android:required="false" />
    <uses-feature android:name="android.hardware.location.gps"      android:required="false" />
    <uses-feature android:name="android.hardware.location.network"  android:required="false" />
    <uses-feature android:name="android.hardware.telephony"         android:required="false" />
    <uses-feature android:name="android.hardware.touchscreen"       android:required="false" />

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- READ/WRITE_EXTERNAL_STORAGE cover Android 12 and below for gallery
         access via the Capacitor camera plugin. From Android 13+ those
         legacy permissions are inert; the camera plugin (v8.0.2+) uses
         Android's system Photo Picker which requires NO storage
         permission at all.
         READ_MEDIA_IMAGES was previously declared here as the Android-13
         counterpart, but Google Play rejects it under the May 2024
         photos-and-videos policy: apps that use photos only
         occasionally (receipt scanning, document upload) MUST go
         through the Photo Picker rather than holding a manifest
         permission. Removing the declaration here is the policy-
         compliant path. -->
    <!-- Scoped to API 32 and below — on Android 13+ these are inert (Photo Picker
         is used instead), and leaving them unscoped triggers Google Play's
         "broad storage access" warning and re-opens the photos/videos policy
         declaration form. v4.4.2 hotfix: add maxSdkVersion to keep them out
         of the runtime permissions list on modern devices. -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- Explicit removal of broad media permissions that @capacitor/camera
         (and any other photo-picker-aware library) might still declare in
         its own manifest as a back-compat fallback. Google Play's May 2024
         "photos and videos" policy rejects any app that uses photos only
         occasionally (receipt scanning, document upload, vehicle photo)
         and still ships these manifest permissions — the policy demands
         the system Photo Picker, which needs NO permission at all.
         tools:node="remove" instructs the manifest merger to strip these
         entries from the final merged AAB even when a library declares
         them. Without this hint, the merger inherits the library's
         permission and the Play Console rejection re-fires on every
         submission.
         Rejection ref: "שימוש לא תקין בהרשאות הגישה לתמונות ולסרטונים" /
         "Invalid use of permissions for photos and videos". -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"
        tools:node="remove" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO"
        tools:node="remove" />
    <uses-permission android:name="android.permission.READ_MEDIA_VISUAL_USER_SELECTED"
        tools:node="remove" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <!-- NOTE: We previously also declared USE_EXACT_ALARM as a "backup"
         for SCHEDULE_EXACT_ALARM. Google Play rejects that declaration
         for reminder/utility apps — USE_EXACT_ALARM is reserved for
         alarm-clock, calendar, and healthcare categories (see
         https://developer.android.com/about/versions/14/changes/schedule-exact-alarms).
         A car-maintenance reminder does not qualify, so the permission
         was removed. SCHEDULE_EXACT_ALARM alone covers our use case:
         it is user-grantable and Capacitor LocalNotifications requests
         it automatically the first time we schedule a reminder. -->
    <!-- REQUEST_IGNORE_BATTERY_OPTIMIZATIONS was previously declared here to
         allow prompting the user to disable Doze battery optimisation for
         the app, BUT no app code actually invokes the prompt
         (`requestIgnoreBatteryOptimizations` / ACTION_REQUEST_IGNORE_BATTERY_OPTIMIZATIONS
         are not called anywhere in src/). Google Play rejects declared-but-
         unused sensitive permissions, and this one is restricted to a narrow
         set of categories (alarm clock, calendar, healthcare, communication).
         A car-maintenance reminder does not qualify. SCHEDULE_EXACT_ALARM
         alone is sufficient: `setExactAndAllowWhileIdle` still fires under
         Doze, it just batches during extreme idle periods (rarely an issue
         for reminders that the user is expecting). -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
</manifest>

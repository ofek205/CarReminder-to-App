#!/usr/bin/env bash
# Project pre-commit gatekeeper - mechanical safety checks.
# Skip with: git commit --no-verify  (don't, unless you know exactly why)

set -e
RED=$'\033[0;31m'; YEL=$'\033[1;33m'; GRN=$'\033[0;32m'; NC=$'\033[0m'
fail() { printf "${RED}[BLOCKED] %s${NC}\n" "$1" >&2; exit 1; }
warn() { printf "${YEL}[warn] %s${NC}\n" "$1" >&2; }
ok()   { printf "${GRN}[ok] %s${NC}\n" "$1"; }

STAGED=$(git diff --cached --name-only --diff-filter=ACM)
[ -z "$STAGED" ] && { ok "nothing staged"; exit 0; }

# 1. Block .env / secret files
echo "$STAGED" | grep -E '(^|/)\.env($|\.|/)|(^|/)credentials\.(json|yaml|yml)$|(^|/)secrets\.(json|yaml|yml)$|\.pem$|\.key$|\.pfx$|id_rsa$' \
  && fail "Secret/credential file staged. Remove with: git restore --staged <file>"
ok "no secret files staged"

# 2. Block merge conflict markers
CONFLICTS=$(git diff --cached -U0 | grep -E '^\+(<<<<<<<|=======|>>>>>>>)' || true)
[ -n "$CONFLICTS" ] && fail "Merge conflict markers found in staged changes."
ok "no conflict markers"

# 3. Block obvious hardcoded secrets in staged content
DIFF=$(git diff --cached -U0)
echo "$DIFF" | grep -E '^\+' | grep -qE 'BEGIN [A-Z ]*PRIVATE KEY' \
  && fail "Private key staged."
echo "$DIFF" | grep -E '^\+' | grep -qE 'sk-(ant-)?[a-zA-Z0-9_\-]{20,}' \
  && fail "Looks like an API key (sk-...) is staged."
echo "$DIFF" | grep -E '^\+' | grep -qE 'AKIA[0-9A-Z]{16}' \
  && fail "AWS access key staged."
echo "$DIFF" | grep -E '^\+' | grep -qE '(ghp|gho|ghs|ghr)_[A-Za-z0-9]{30,}' \
  && fail "GitHub token staged."
ok "no obvious secrets in diff"

# 4. Warn about console.log / debugger in src/
SRC_FILES=$(echo "$STAGED" | grep -E '^src/.*\.(js|jsx|ts|tsx)$' || true)
if [ -n "$SRC_FILES" ]; then
  ADDED_LOGS=$(git diff --cached -U0 -- $SRC_FILES | grep -E '^\+' | grep -cE '(^|[^.])console\.(log|debug)\(|debugger;' || true)
  [ "${ADDED_LOGS:-0}" -gt 0 ] && warn "$ADDED_LOGS new console.log/debugger added in src/. Consider removing."
fi

# 5. Lint staged JS/JSX (fast — only changed files)
LINT_FILES=$(echo "$STAGED" | grep -E '\.(js|jsx|ts|tsx)$' || true)
if [ -n "$LINT_FILES" ] && [ -x node_modules/.bin/eslint ]; then
  echo "$LINT_FILES" | xargs node_modules/.bin/eslint --quiet \
    || fail "ESLint failed on staged files. Fix with: npm run lint:fix"
  ok "eslint passed on staged files"
else
  [ -z "$LINT_FILES" ] || warn "eslint not found in node_modules — skipping lint"
fi

# 6. Reminder about Claude gatekeeper
printf "${GRN}[ok] mechanical checks passed${NC}\n"
printf "${YEL}[reminder] If committing via Claude Code, the commit-gatekeeper skill must also produce APPROVED.${NC}\n"
exit 0

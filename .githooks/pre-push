#!/usr/bin/env bash
# Project pre-push gatekeeper - heavier checks before code leaves the machine.
# Skip with: git push --no-verify  (don't, unless you know exactly why)

set -e
RED=$'\033[0;31m'; YEL=$'\033[1;33m'; GRN=$'\033[0;32m'; NC=$'\033[0m'
fail() { printf "${RED}[BLOCKED] %s${NC}\n" "$1" >&2; exit 1; }
ok()   { printf "${GRN}[ok] %s${NC}\n" "$1"; }

# 1. Block direct push to main / master
while read -r local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/heads/main|refs/heads/master)
      printf "${YEL}[warn] Pushing directly to %s. Press Ctrl+C in 5s to cancel...${NC}\n" "$remote_ref" >&2
      sleep 5
      ;;
  esac
done

# 2. Full ESLint
if [ -x node_modules/.bin/eslint ]; then
  npm run -s lint || fail "ESLint failed. Fix with: npm run lint:fix"
  ok "eslint passed"
fi

# 3. Production build must succeed
if [ -x node_modules/.bin/vite ]; then
  npm run -s build || fail "Production build failed."
  ok "build passed"
fi

printf "${GRN}[ok] pre-push checks passed${NC}\n"
exit 0

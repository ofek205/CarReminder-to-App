#!/bin/sh
# Project pre-push gatekeeper - heavier checks before code leaves the machine.
# Skip with: git push --no-verify  (don't, unless you know exactly why)
#
# Portable shebang: uses /bin/sh, NOT `/usr/bin/env bash`. GitHub Desktop on
# Windows runs git with a stripped PATH where `env` can't find `bash`
# (/usr/bin/env: 'bash': No such file or directory) — which aborted the push.
# git always resolves /bin/sh via its bundled shell, so the hook starts.
# When node/npm aren't on PATH (GitHub Desktop's git env), the tool-dependent
# checks are SKIPPED with a warning instead of blocking — those same checks run
# in CI on every PR to main, and in any real dev terminal that has npm.

set -e
RED='\033[0;31m'; YEL='\033[1;33m'; GRN='\033[0;32m'; NC='\033[0m'
fail() { printf "${RED}[BLOCKED] %s${NC}\n" "$1" >&2; exit 1; }
warn() { printf "${YEL}[warn] %s${NC}\n" "$1" >&2; }
ok()   { printf "${GRN}[ok] %s${NC}\n" "$1"; }

# 1. Warn on direct push to main / master
while read -r local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/heads/main|refs/heads/master)
      warn "Pushing directly to $remote_ref. Press Ctrl+C in 5s to cancel..."
      sleep 5 || true
      ;;
  esac
done

HAVE_NPM=0;  if command -v npm  >/dev/null 2>&1; then HAVE_NPM=1;  fi
HAVE_NODE=0; if command -v node >/dev/null 2>&1; then HAVE_NODE=1; fi

if [ "$HAVE_NPM" = 1 ]; then
  # 2. Full ESLint
  if [ -x node_modules/.bin/eslint ]; then
    npm run -s lint || fail "ESLint failed. Fix with: npm run lint:fix"
    ok "eslint passed"
  fi
  # 3. Production build must succeed
  if [ -x node_modules/.bin/vite ]; then
    npm run -s build || fail "Production build failed."
    ok "build passed"
  fi
else
  warn "npm not found (e.g. GitHub Desktop git env) - skipping local lint/build. CI enforces them on PR to main."
fi

# 4. Query-timeout gate - every Supabase call inside a useQuery must be wrapped
# with withTimeout(...) or Promise.race(...). Only needs node, so run it whenever
# node is present even if npm is not. See scripts/check-query-timeouts.cjs.
if [ "$HAVE_NODE" = 1 ] && [ -f scripts/check-query-timeouts.cjs ]; then
  node scripts/check-query-timeouts.cjs || fail "check-query-timeouts gate failed."
  ok "query-timeout gate passed"
elif [ "$HAVE_NODE" != 1 ]; then
  warn "node not found - skipping query-timeout gate. CI enforces it on PR to main."
fi

printf "${GRN}[ok] pre-push checks done${NC}\n"
exit 0

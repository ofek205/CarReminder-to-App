#env
.env
.env.*

# App Store binary assets — generated from the running dev server,
# uploaded to App Store Connect manually. Keep the metadata.md and
# generator scripts in git; skip the heavy PNGs.
app-store/*.png
app-store/final/
apple-icon-*.png

# App Store Connect API key — never commit
.apple-review-creds
AuthKey_*.p8

# iOS signing artifacts — distribution cert (.p12), provisioning profile,
# and the password used to encrypt the .p12. scripts/setup-ios-signing.cjs
# emits these to .ios-signing/ as a "paste these into GitHub Secrets" copy
# but they MUST NOT live in git: anyone with read access to the repo can
# sign + ship binaries as our team. Untracking only stops the bleed; if
# these were ever pushed to the remote, rotate the cert in Apple Developer
# and `git filter-repo` the history.
.ios-signing/
IOS_DIST_CERT_BASE64.txt
IOS_DIST_CERT_PASSWORD.txt
IOS_PROFILE_NAME.txt

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

.env

# Android build artifacts
android/app/build/
android/.gradle/
android/build/
android/capacitor-cordova-android-plugins/build/
*.keystore
*.jks


#env
.env
.env.*

# App Store binary assets — generated from the running dev server,
# uploaded to App Store Connect manually. Keep the metadata.md and
# generator scripts in git; skip the heavy PNGs.
app-store/*.png
app-store/final/
apple-icon-*.png

# App Store Connect API key — never commit
.apple-review-creds
AuthKey_*.p8

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

.env

# Android build artifacts
android/app/build/
android/.gradle/
android/build/
android/capacitor-cordova-android-plugins/build/
*.keystore
*.jks

# iOS build artifacts
ios/App/build/
ios/App/Pods/
ios/DerivedData/
ios/App/App/public/

# Claude local files
.claude/plans/
.claude/shell-snapshots/
.claude/todos/
.claude/projects/

# Supabase CLI local state (linked-project.json, version pins, etc.)
supabase/.temp/
# Local DB credentials — never commit
db-password.txt
staging-db-url.txt
schema-prod.sql
# Generated by scripts/build-staging-init.sh — re-create on demand,
# never commit (374KB; would also bloat diffs).
staging-init-consolidated.sql

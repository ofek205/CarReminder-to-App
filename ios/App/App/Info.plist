<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CAPACITOR_DEBUG</key>
	<string>$(CAPACITOR_DEBUG)</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>he</string>
	<key>CFBundleLocalizations</key>
	<array>
		<string>he</string>
		<string>en</string>
	</array>
	<key>NSCameraUsageDescription</key>
	<string>האפליקציה משתמשת במצלמה כדי לסרוק רישיון רכב, פוליסת ביטוח ומסמכים נוספים — כך פרטי הרכב מתמלאים אוטומטית בלי הקלדה ידנית.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>האפליקציה צריכה גישה לתמונות כדי לטעון מסמכים שכבר צילמת ולשמור תמונות של רכבים ותיקונים.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>האפליקציה שומרת לאלבום שלך תמונות של מסמכים סרוקים וקבלות, כדי שיהיו זמינות גם מחוץ לאפליקציה.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>האפליקציה מציגה מוסכים, חנויות חלקים ותחנות בקרבת מיקומך הנוכחי. המיקום אינו נשמר בשרת.</string>
	<key>CFBundleDisplayName</key>
        <string>CarReminders</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<!-- Background Modes — required for remote push delivery while the
	     app is backgrounded or terminated. Without 'remote-notification'
	     iOS surfaces the banner only while the app is in the foreground
	     and silently drops it otherwise. This is the Info.plist twin of
	     the "Background Modes → Remote notifications" Xcode capability. -->
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
	<!-- Custom URL scheme registration — REQUIRED for native OAuth.
	     The Google sign-in flow (and every other deep link of the form
	     carreminder://...) redirects to this scheme. Without this
	     declaration iOS does not know the scheme belongs to us and
	     Safari shows "Safari cannot open the page because the address
	     is invalid" — the user is stuck on a blank Safari page right
	     after completing the Google consent screen.
	     CFBundleURLName uses the reverse-DNS bundle id; the scheme name
	     "carreminder" must match what the JS layer passes as
	     `redirectTo` in supabase.auth.signInWithOAuth (AuthPage.jsx)
	     and what initDeepLinks listens for (lib/capacitor.js). -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.carreminders.app</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>carreminder</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
